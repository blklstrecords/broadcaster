[Unit]
Description=Update Cloudflare DNS record for the live stream
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=broadcaster
Group=broadcaster
Environment=LANG=C.UTF-8
Environment=LC_ALL=C.UTF-8
ExecStart=/opt/broadcaster/bin/dns-update.sh
EnvironmentFile=/etc/broadcaster/broadcaster.env

[Install]
WantedBy=multi-user.target
